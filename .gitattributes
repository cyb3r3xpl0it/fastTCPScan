# Normaliza los finales de línea a LF en todo el repositorio.
* text=auto eol=lf

*.go    text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.mod   text eol=lf
*.sum   text eol=lf
Makefile    text eol=lf
Dockerfile  text eol=lf
.gitignore     text eol=lf
.dockerignore  text eol=lf

# Binarios (no tocar).
*.png binary
*.jpg binary
*.gz  binary
*.zip binary
